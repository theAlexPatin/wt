{
  "expo": {
    "name": "Wit",
    "slug": "wt-companion",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "wt",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0f"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.owner.wit-companion",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-font",
      "expo-notifications",
      "expo-camera",
      "expo-image-picker",
      [
        "expo-build-properties",
        {
          "ios": {
            "newArchEnabled": true
          }
        }
      ],
      "./plugins/withFollyNoCoroutines"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a671143b-7d4c-4f99-ab53-b24634e0c7e1"
      }
    },
    "owner": "owner-com",
    "android": {
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.owner.witcompanion"
    },
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "updates": {
      "url": "https://u.expo.dev/a671143b-7d4c-4f99-ab53-b24634e0c7e1"
    }
  }
}
