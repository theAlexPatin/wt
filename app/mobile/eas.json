{
  "cli": {
    "version": ">= 15.0.0"
  },
  "build": {
    "development": {
      "distribution": "internal",
      "ios": {
        "buildConfiguration": "Debug"
      }
    },
    "development-sim": {
      "distribution": "internal",
      "ios": {
        "buildConfiguration": "Debug",
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "FOLLY_CFG_NO_COROUTINES": "1"
      }
    },
    "production": {
      "distribution": "store"
    }
  }
}
